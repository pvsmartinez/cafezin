{
  "outputDirectory": "landing",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "cookie",
          "key": "cafezin_locale",
          "value": "pt-BR"
        }
      ],
      "destination": "/br",
      "permanent": false
    },
    {
      "source": "/",
      "missing": [
        {
          "type": "cookie",
          "key": "cafezin_locale"
        }
      ],
      "has": [
        {
          "type": "header",
          "key": "accept-language",
          "value": "(^|.*[;, ]+)pt(?:-BR)?(?:[;,].*|$)"
        }
      ],
      "destination": "/br",
      "permanent": false
