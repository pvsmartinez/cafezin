{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cafezin",
  "version": "0.1.8",
  "identifier": "com.pvsmartinez.cafezin",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cafezin",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "iOS": {
      "developmentTeam": "8VV48629P3"
    },
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDRjE5RjkxMzM1NDNCRjMKUldUek8xUXprWi94UEhhMFp3NFovMzJnQThWTG80QkxDVVVvRURHa2xYSENQVUtOcTZNbnFnd0cK",
      "endpoints": [
        "https://raw.githubusercontent.com/pvsmartinez/cafezin/main/update/latest.json"
      ]
    },
    "deep-link": {
      "mobile": [
        {
          "scheme": [
            "cafezin"
          ],
          "host": "auth",
          "pathPrefix": [
            "/callback"
          ]
        }
      ],
      "desktop": {
        "schemes": [
          "cafezin"
        ]
      }
    }
  }
}
